<launch>
<!-- Launch file for Livox AVIA LiDAR -->

	<arg name="rviz" default="true" />

	<rosparam file="$(find livox2cam_calibration)/config/qr_params.yaml" command="load" subst_value="true"/>

	<node pkg="livox2cam_calibration" type="livox2cam_calibration" name="livox2cam_calibration" output="screen">
	</node>
	
	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find livox2cam_calibration)/rviz_cfg/livox2cam_calibration.rviz" />
	</group>
launch-prefix="gdb -ex run --args"
launch-prefix="valgrind --leak-check=full"
</launch> 	
